{
  "name": "@dataforge/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "esbuild src/index.ts src/schema/*.ts --outdir=dist --format=esm --platform=node && tsc --emitDeclarationOnly --declaration --outDir dist || true",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit migrate",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "drizzle-orm": "^0.30.0",
    "postgres": "^3.4.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "devDependencies": {
    "drizzle-kit": "^0.21.0"
  }
}