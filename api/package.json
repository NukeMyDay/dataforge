    "drizzle-orm": "^0.30.0",
    "nodemailer": "^6.9.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^6.4.0",
    "typescript": "^5.4.0",
    "tsx": "^4.7.0"
  }
