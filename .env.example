# DataForge — Environment Variables
# Copy this file to .env and fill in all required values.
# Required variables are marked [REQUIRED]. Others have safe defaults.

# ─── Database ──────────────────────────────────────────────────────────────────
# [REQUIRED] PostgreSQL connection string
DATABASE_URL=postgres://dataforge:dataforge@localhost:5432/dataforge

# ─── API ───────────────────────────────────────────────────────────────────────
# Port the Hono API listens on (default: 3000)
PORT=3000

# [REQUIRED] Secret used to sign JWTs. Generate with: openssl rand -hex 32
JWT_SECRET=change-me-in-production

# [REQUIRED] Password for the built-in admin account (admin@dataforge.local)
ADMIN_PASSWORD=change-me-in-production

# ─── AI Chat ───────────────────────────────────────────────────────────────────
# Anthropic API key for the /v1/chat endpoint.
# Get one at: https://console.anthropic.com
# If unset, the chat endpoint returns 503.
ANTHROPIC_API_KEY=

# ─── Payments (optional) ───────────────────────────────────────────────────────
# Stripe keys for subscription management
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price ID for the Pro plan (create in Stripe Dashboard → Products)
STRIPE_PRO_PRICE_ID=price_...

# Base URL of the public web app (used in checkout redirect URLs)
WEB_BASE_URL=https://gonear.de

# ─── Email (optional) ──────────────────────────────────────────────────────────
# SMTP settings for transactional emails (not yet implemented)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@gonear.de

# ─── Web frontend (build-time) ─────────────────────────────────────────────────
# API base URL used by the web and admin React apps at build time.
# Leave empty to use the Vite dev proxy (default for local dev).
VITE_API_URL=
