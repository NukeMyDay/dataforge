{
  "name": "dataforge",
  "version": "0.1.0",
  "private": true,
  "description": "Structured Data Platform \u2014 Education & Regulatory verticals",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @dataforge/db generate",
    "db:migrate": "pnpm --filter @dataforge/db migrate"
  },
  "workspaces": [
    "api",
    "pipelines",
    "db",
    "shared",
    "web",
    "admin"
  ],
  "devDependencies": {
    "esbuild": "^0.21.0"
  }
}